{
  "name": "tanstack-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:mock\"",
    "dev:all": "pnpm db:up && concurrently \"pnpm dev:server\" \"pnpm dev:mock\"",
    "dev:server": "vite dev --port 3000",
    "dev:mock": "json-server --watch mocks/db.json --port 3001",
    "mock": "json-server --watch mocks/db.json --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test:visual": "percy exec -- playwright test",
    "rag:ingest": "tsx scripts/ingest-rag.ts",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "setup:rag": "pnpm run db:up && echo 'Waiting for ChromaDB...' && sleep 5 && pnpm run rag:ingest"
  },
