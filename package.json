{
  "name": "tanstack-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:mock\"",
    "dev:server": "vite dev --port 3000",
    "dev:mock": "json-server --watch mocks/db.json --port 3001",
    "mock": "json-server --watch mocks/db.json --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/tanstack-start": "^0.11.5",
