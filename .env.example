
# budget-app — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# See tasks/env-unification-plan.md for the full naming convention reference.
# NEVER commit .env — only .env.example is tracked.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000          # Public base URL (auth redirects, webhooks)

# ── Database ──────────────────────────────────────────────────────────────────
# Dev DB runs on port 5435 to avoid conflicts when running multiple apps
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/budget_app

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid                  # client-side mirror — must match AUTH_MODE
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32  # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000  # must match APP_URL
# Clerk (required when AUTH_MODE=clerk or hybrid)
CLERK_SECRET_KEY=                      # sk_test_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_test_... from clerk.com → API Keys
# Cron jobs
# CRON_SECRET=                         # openssl rand -hex 32

# ── AI — Local Providers (development only — NOT used in production) ──────────
# Unified AI backend (development only)
# Set this to the base URL of your preferred local AI provider (Ollama, llama.cpp, LM Studio, etc.)
AI_API_BASE_URL=http://localhost:11435/v1  # Default: Ollama

# These point to the shared workspace containers started from the workspace root:
#   docker compose --profile ai up -d
#

# Individual provider URLs (override AI_API_BASE_URL if needed)
AI_OLLAMA_BASE_URL=http://localhost:11435/v1
AI_LLAMA_CPP_BASE_URL=http://localhost:8080/v1
AI_LMSTUDIO_BASE_URL=http://localhost:1234/v1
AI_OLLAMA_MODEL=qwen3.5:2b
AI_LMSTUDIO_MODEL=qwen3.5-2b
OLLAMA_ORIGINS=*
# Legacy alias — prefer AI_API_BASE_URL above.
VITE_AI_BASE_URL=http://localhost:11435/v1

# ── AI — Cloud Providers (production) ─────────────────────────────────────────
MINIMAX_API_KEY=                      # from platform.minimaxi.chat (primary LLM)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M1
OPENAI_API_KEY=                       # optional fallback
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=                    # optional fallback
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Default local admin (seeded by db:seed:admin) ────────────────────────────
# Run `pnpm db:seed:admin` after migrations to create the initial admin user.
# These same values live in the workspace-level .env so they stay consistent.
DEFAULT_ADMIN_EMAIL=edd_admin@local.com
DEFAULT_ADMIN_PASSWORD=Passw0rd!234

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                      # from sentry.io → Project → DSN (empty = disabled)
